# ================================
# TM Airlines RAG Service - Config
# ================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- FastAPI ---
APP_NAME="TM Airlines RAG Service"
APP_VERSION="0.1.0"
DEBUG=false
ALLOWED_ORIGINS=["*"]

# --- PostgreSQL / pgvector ---
DATABASE_URL=postgresql://user:password@localhost:5432/tm_airlines
PGVECTOR_COLLECTION_NAME=tm_airlines_docs

# --- NVIDIA AI Endpoints ---
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_MAX_TOKENS=1024
NVIDIA_TEMPERATURE=0.2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
